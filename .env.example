# LocoTrainer Configuration
# Copy this to .env and fill in your values.

# ── API (OpenAI-compatible) ──────────────────────────────────────────────
# Any OpenAI-compatible endpoint works: OpenAI, DashScope, OpenRouter,
# MiniMax, Ollama, etc.
LOCOTRAINER_API_KEY=sk-your-key-here
LOCOTRAINER_BASE_URL=https://api.openai.com/v1
LOCOTRAINER_MODEL=gpt-4o

# ── Provider presets ─────────────────────────────────────────────────────
# Instead of setting BASE_URL and MODEL manually, use a provider preset:
# LOCOTRAINER_PROVIDER=minimax   # or: openai, dashscope, openrouter
# The preset sets base_url + default model automatically.
# You can still override MODEL or BASE_URL explicitly.

# ── Alternative: use provider-specific env vars ──────────────────────────
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# MINIMAX_API_KEY=your-minimax-key
# DASHSCOPE_API_KEY=your-dashscope-key

# ── Agent settings ───────────────────────────────────────────────────────
LOCOTRAINER_MAX_TURNS=20
LOCOTRAINER_MAX_TOKENS=8192

# ── Sampling parameters ──────────────────────────────────────────────────
# Adjust these for vLLM or other inference engines
LOCOTRAINER_TEMPERATURE=0.7
LOCOTRAINER_TOP_P=0.9
LOCOTRAINER_FREQUENCY_PENALTY=0.0
LOCOTRAINER_PRESENCE_PENALTY=0.0

# ── Thinking mode (for Qwen, DeepSeek, etc.) ────────────────────────────
# LOCOTRAINER_ENABLE_THINKING=true
# LOCOTRAINER_THINKING_BUDGET=8192

# ── Paths ────────────────────────────────────────────────────────────────
# LOCOTRAINER_CODEBASE=/path/to/your/project
# LOCOTRAINER_OUTPUT_DIR=./output
